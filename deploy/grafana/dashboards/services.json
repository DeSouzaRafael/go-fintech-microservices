{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "RED metrics and latency percentiles for all fintech services",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Request Rate",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 2,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table" } },
      "targets": [
        {
          "expr": "sum by (job) (rate(rpc_server_duration_milliseconds_count[1m]))",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "title": "gRPC Request Rate by Service",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "percentunit",
          "max": 1
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 3,
      "targets": [
        {
          "expr": "sum by (job) (rate(rpc_server_duration_milliseconds_count{rpc_grpc_status_code!=\"0\"}[1m])) / sum by (job) (rate(rpc_server_duration_milliseconds_count[1m]))",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "title": "gRPC Error Rate by Service",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 10,
      "title": "Latency Percentiles",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 10 },
      "id": 11,
      "options": {
        "legend": { "calcs": ["mean", "p95", "max"], "displayMode": "table" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (job, le) (rate(rpc_server_duration_milliseconds_bucket[5m])))",
          "legendFormat": "p50 {{job}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (job, le) (rate(rpc_server_duration_milliseconds_bucket[5m])))",
          "legendFormat": "p95 {{job}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (job, le) (rate(rpc_server_duration_milliseconds_bucket[5m])))",
          "legendFormat": "p99 {{job}}",
          "refId": "C"
        }
      ],
      "title": "gRPC Latency Percentiles (p50 / p95 / p99)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 20,
